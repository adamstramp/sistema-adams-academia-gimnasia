                                        <th>Nombre</th>
                                        <th>ASOC</th>
                                        <th>IND</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${juecesIND.length === 0 ? '<tr><td colspan="5" class="text-center text-gray">No hay jueces IND</td></tr>' : 
                                        juecesIND.map((j, idx) => `
                                            <tr>
                                                <td><span class="juez-numero">${idx + 1}</span></td>
                                                <td>${j.nombre}</td>
                                                <td>${j.asoc}</td>
                                                <td>${j.ind}</td>
                                                <td>
                                                    <button class="btn btn-secondary btn-sm" onclick="editarJuezEvento(${j.id})">✏️</button>
                                                    <button class="btn btn-danger btn-sm" onclick="eliminarJuezEvento(${j.id})">🗑️</button>
