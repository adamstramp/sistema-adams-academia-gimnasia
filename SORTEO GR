        actualizarFuncion(panelNum, funcion, numero);
    } else {
        if (inputNombre) inputNombre.value = '';
        actualizarFuncion(panelNum, funcion, '');
    }
}

function mostrarDropdownNombre(panelNum, funcion) {
    const juecesRef = sorteoActual.tipo === 'IND' ? sorteoActual.juecesIND : sorteoActual.jucesCONJ;
    const dropdown = document.getElementById(`dropdown-nombre-${panelNum}-${funcion}`);
    const input = document.getElementById(`input-nombre-${panelNum}-${funcion}`);
    
    if (!input || !dropdown) return;
    
    const valorActual = input.value.trim().toUpperCase();
    
    // Si hay texto, filtrar; si no, mostrar todos
    const juecesFiltrados = valorActual.length > 0 
        ? juecesRef.filter(j => j.nombre.toUpperCase().includes(valorActual))
        : juecesRef;
    
    renderizarDropdownNombre(dropdown, juecesFiltrados, panelNum, funcion);
    dropdown.classList.add('active');
}

function filtrarDesdeNombre(panelNum, funcion, input) {
    const valor = input.value.trim().toUpperCase();
    const juecesRef = sorteoActual.tipo === 'IND' ? sorteoActual.juecesIND : sorteoActual.jucesCONJ;
    const dropdown = document.getElementById(`dropdown-nombre-${panelNum}-${funcion}`);
    
    if (!dropdown) return;
    
    // Filtrar jueces por nombre
    const juecesFiltrados = valor.length > 0
        ? juecesRef.filter(j => j.nombre.toUpperCase().includes(valor))
        : juecesRef;
    
    renderizarDropdownNombre(dropdown, juecesFiltrados, panelNum, funcion);
    dropdown.classList.add('active');
}

function renderizarDropdownNombre(dropdown, jueces, panelNum, funcion) {
    if (!dropdown) return;
    
    if (jueces.length === 0) {
        dropdown.innerHTML = '<div class="dropdown-nombre-item text-gray">No se encontraron jueces</div>';
        return;
    }
    
    dropdown.innerHTML = jueces.map(juez => `
        <div class="dropdown-nombre-item" onclick="seleccionarJuezPorNombre(${panelNum}, '${funcion}', ${juez.numero}, '${juez.nombre.replace(/'/g, "\\'")}', '${juez.asoc.replace(/'/g, "\\'")}')">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="display: inline-block; width: 25px; height: 25px; background: #db2777; color: white; border-radius: 50%; text-align: center; line-height: 25px; font-weight: bold; font-size: 0.75rem;">${juez.numero}</span>
                <div style="flex: 1;">
                    <div><strong>${juez.nombre}</strong></div>
                    <div style="font-size: 0.75rem; color: #6b7280;">${juez.asoc}</div>
                </div>
            </div>
        </div>
    `).join('');
}

function seleccionarJuezPorNombre(panelNum, funcion, numero, nombre, asoc) {
    const inputNum = document.getElementById(`input-num-${panelNum}-${funcion}`);
    const inputNombre = document.getElementById(`input-nombre-${panelNum}-${funcion}`);
    const dropdown = document.getElementById(`dropdown-nombre-${panelNum}-${funcion}`);
    
    // Actualizar ambos campos
    if (inputNum) inputNum.value = numero;
    if (inputNombre) inputNombre.value = nombre;
    
    // Cerrar dropdown
    if (dropdown) dropdown.classList.remove('active');
    
    // Guardar en la función
    actualizarFuncion(panelNum, funcion, numero.toString());
}

function cerrarDropdownNombre(panelNum, funcion) {
    const dropdown = document.getElementById(`dropdown-nombre-${panelNum}-${funcion}`);
    const inputNombre = document.getElementById(`input-nombre-${panelNum}-${funcion}`);
    const inputNum = document.getElementById(`input-num-${panelNum}-${funcion}`);
    
    if (!dropdown) return;
    
    dropdown.classList.remove('active');
    
    // Verificar si hay texto parcial y completar
    const valor = inputNombre ? inputNombre.value.trim().toUpperCase() : '';
    if (valor.length > 0) {
        const juecesRef = sorteoActual.tipo === 'IND' ? sorteoActual.juecesIND : sorteoActual.jucesCONJ;
        const juezEncontrado = juecesRef.find(j => 
            j.nombre.toUpperCase().startsWith(valor)
        );
        
        if (juezEncontrado) {
            if (inputNombre) inputNombre.value = juezEncontrado.nombre;
            if (inputNum) inputNum.value = juezEncontrado.numero;
            actualizarFuncion(panelNum, funcion, juezEncontrado.numero.toString());
        } else {
            // No encontró coincidencia
            if (inputNombre) inputNombre.value = '';
            if (inputNum) inputNum.value = '';
            actualizarFuncion(panelNum, funcion, '');
        }
    }
}

