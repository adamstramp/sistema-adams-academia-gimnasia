        function crearSorteo() {
            const tipo = document.querySelector('input[name="tipoSorteo"]:checked').value;
            const categorias = Array.from(document.querySelectorAll('#listaCategoriasSorteo input:checked')).map(cb => cb.value);
            const numPaneles = parseInt(document.querySelector('input[name="numPaneles"]:checked').value);
            
            if (categorias.length === 0) {
                alert('Debe seleccionar al menos una categoría');
                return;
            }
            
            const juecesEvento = eventoActual.jueces || [];
            const juecesIND = ordenarJueces(juecesEvento.filter(j => j.ind), 'ind').map((j, idx) => ({ ...j, numero: idx + 1 }));
            const jucesCONJ = ordenarJueces(juecesEvento.filter(j => j.conj), 'conj').map((j, idx) => ({ ...j, numero: idx + 1 }));
            
            const paneles = [];
            for (let i = 1; i <= numPaneles; i++) {
                paneles.push({
                    num: i,
                    implementos: [],
                    omitirAlertas: false,
                    funciones: {}
                });
            }
            
            const sorteo = {
                id: Date.now(),
                tipo,
                categorias,
                numPaneles,
                juecesIND,
                jucesCONJ,
                paneles
            };
            
            if (!eventoActual.sorteos) eventoActual.sorteos = [];
            eventoActual.sorteos.push(sorteo);
            
            const index = eventos.findIndex(e => e.id === eventoActual.id);
            eventos[index] = eventoActual;
            guardarDatos();
            
            cerrarModal('modalCrearSorteo');
            renderizarDetalleEvento();
        }

