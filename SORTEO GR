        function verificarConflicto(panel, funcion) {
            if (panel.omitirAlertas) return '';
            
            const rubros = {
                'DB1': ['DB1', 'DB2'],
                'DB2': ['DB1', 'DB2'],
                'DA1': ['DA1', 'DA2'],
                'DA2': ['DA1', 'DA2'],
                'A1': ['A1', 'A2', 'A3', 'A4'],
                'A2': ['A1', 'A2', 'A3', 'A4'],
                'A3': ['A1', 'A2', 'A3', 'A4'],
                'A4': ['A1', 'A2', 'A3', 'A4'],
                'E1': ['E1', 'E2', 'E3', 'E4'],
                'E2': ['E1', 'E2', 'E3', 'E4'],
                'E3': ['E1', 'E2', 'E3', 'E4'],
                'E4': ['E1', 'E2', 'E3', 'E4']
            };
            
            if (!rubros[funcion]) return '';
            
            const juecesRef = sorteoActual.tipo === 'IND' ? sorteoActual.juecesIND : sorteoActual.jucesCONJ;
            const funcionesRubro = rubros[funcion];
            const asocs = [];
            
            funcionesRubro.forEach(f => {
                const numero = (typeof panel.funciones[f] === 'object') ? panel.funciones[f].numero : panel.funciones[f];
                if (numero) {
                    const juez = juecesRef.find(j => j.numero === parseInt(numero));
                    if (juez) asocs.push(juez.asoc);
                }
            });
            
            const numeroActual = (typeof panel.funciones[funcion] === 'object') ? panel.funciones[funcion].numero : panel.funciones[funcion];
            if (numeroActual) {
                const juezActual = juecesRef.find(j => j.numero === parseInt(numeroActual));
                if (juezActual) {
                    const duplicados = asocs.filter(a => a === juezActual.asoc);
                    if (duplicados.length > 1) {
                        return 'alert-warning';
                    }
                }
            }
            
            return '';
        }

        function actualizarSorteo() {
            const sorteoIndex = eventoActual.sorteos.findIndex(s => s.id === sorteoActual.id);
            eventoActual.sorteos[sorteoIndex] = sorteoActual;
            
            const eventoIndex = eventos.findIndex(e => e.id === eventoActual.id);
            eventos[eventoIndex] = eventoActual;
            guardarDatos();
        }

