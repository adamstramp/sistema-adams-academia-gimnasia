        function ordenarJueces(juecesArray, campo) {
            return juecesArray.sort((a, b) => {
                const indexA = NIVELES_ORDEN.indexOf(a[campo]);
                const indexB = NIVELES_ORDEN.indexOf(b[campo]);
                return indexA - indexB;
            });
        }

        function mostrarSelectorJueces() {
            juecesSeleccionados = (eventoActual.jueces || []).map(j => j.id);
            const tbody = document.querySelector('#tablaSelectorJueces tbody');
            tbody.innerHTML = '';
            
            jueces.forEach(juez => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><input type="checkbox" ${juecesSeleccionados.includes(juez.id) ? 'checked' : ''} onchange="toggleJuezSelector(${juez.id})"></td>
                    <td>${juez.nombre}</td>
                    <td>${juez.asoc}</td>
                    <td>${juez.ind}</td>
                    <td>${juez.conj}</td>
                `;
                tbody.appendChild(tr);
            });
            
            actualizarContadorSeleccionados();
            document.getElementById('modalSelectorJueces').classList.add('active');
        }

        function toggleJuezSelector(id) {
            if (juecesSeleccionados.includes(id)) {
                juecesSeleccionados = juecesSeleccionados.filter(jid => jid !== id);
            } else {
                juecesSeleccionados.push(id);
            }
            actualizarContadorSeleccionados();
        }

        function actualizarContadorSeleccionados() {
            document.getElementById('contadorSeleccionados').textContent = `${juecesSeleccionados.length} jueces seleccionados`;
        }

        function filtrarJuecesSelector() {
            const filtro = document.getElementById('filtroJueces').value.toLowerCase();
            const tbody = document.querySelector('#tablaSelectorJueces tbody');
            tbody.innerHTML = '';
            
            const jucesFiltrados = jueces.filter(j => 
                j.nombre.toLowerCase().includes(filtro) ||
                j.asoc.toLowerCase().includes(filtro) ||
                (j.ind && j.ind.toLowerCase().includes(filtro)) ||
                (j.conj && j.conj.toLowerCase().includes(filtro))
            );
            
            jucesFiltrados.forEach(juez => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><input type="checkbox" ${juecesSeleccionados.includes(juez.id) ? 'checked' : ''} onchange="toggleJuezSelector(${juez.id})"></td>
                    <td>${juez.nombre}</td>
                    <td>${juez.asoc}</td>
                    <td>${juez.ind}</td>
                    <td>${juez.conj}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function guardarJuecesEvento() {
            const juecesToAdd = jueces.filter(j => juecesSeleccionados.includes(j.id));
            eventoActual.jueces = juecesToAdd.map(j => ({ ...j }));
            
            const index = eventos.findIndex(e => e.id === eventoActual.id);
            eventos[index] = eventoActual;
            guardarDatos();
            
            cerrarModal('modalSelectorJueces');
            renderizarDetalleEvento();
        }

        function editarJuezEvento(juezId) {
            editandoJuezEventoId = juezId;
            const juez = eventoActual.jueces.find(j => j.id === juezId);
            
            document.getElementById('infoJuezEvento').textContent = `${juez.nombre} - ${juez.asoc}`;
            document.getElementById('juezEventoInd').value = juez.ind || '';
            document.getElementById('juezEventoConj').value = juez.conj || '';
            
            document.getElementById('modalEditarJuezEvento').classList.add('active');
        }

        function guardarJuezEvento() {
            const index = eventoActual.jueces.findIndex(j => j.id === editandoJuezEventoId);
            eventoActual.jueces[index].ind = document.getElementById('juezEventoInd').value.trim();
            eventoActual.jueces[index].conj = document.getElementById('juezEventoConj').value.trim();
            
            const eventoIndex = eventos.findIndex(e => e.id === eventoActual.id);
            eventos[eventoIndex] = eventoActual;
            guardarDatos();
            
            cerrarModal('modalEditarJuezEvento');
            renderizarDetalleEvento();
        }

        function eliminarJuezEvento(juezId) {
            if (confirm('¿Eliminar este juez del evento?')) {
                eventoActual.jueces = eventoActual.jueces.filter(j => j.id !== juezId);
                
                const index = eventos.findIndex(e => e.id === eventoActual.id);
                eventos[index] = eventoActual;
                guardarDatos();
                
                renderizarDetalleEvento();
            }
        }

        // ===== GESTIÓN DE SORTEOS =====

        function abrirModalCrearSorteo() {
            cambiarTipoSorteo();
            document.getElementById('modalCrearSorteo').classList.add('active');
        }

        function cambiarTipoSorteo() {
            const tipo = document.querySelector('input[name="tipoSorteo"]:checked').value;
            const categorias = tipo === 'IND' ? CATEGORIAS_IND : CATEGORIAS_CONJ;
            const lista = document.getElementById('listaCategoriasSorteo');
            
            lista.innerHTML = categorias.map(cat => `
                <label class="categoria-checkbox">
                    <input type="checkbox" value="${cat}"> ${cat}
                </label>
            `).join('');
        }

        function crearSorteo() {
            const tipo = document.querySelector('input[name="tipoSorteo"]:checked').value;
            const categorias = Array.from(document.querySelectorAll('#listaCategoriasSorteo input:checked')).map(cb => cb.value);
            const numPaneles = parseInt(document.querySelector('input[name="numPaneles"]:checked').value);
            
            if (categorias.length === 0) {
                alert('Debe seleccionar al menos una categoría');
                return;
            }
            
            const juecesEvento = eventoActual.jueces || [];
            const juecesIND = ordenarJueces(juecesEvento.filter(j => j.ind), 'ind').map((j, idx) => ({ ...j, numero: idx + 1 }));
            const jucesCONJ = ordenarJueces(juecesEvento.filter(j => j.conj), 'conj').map((j, idx) => ({ ...j, numero: idx + 1 }));
            
            const paneles = [];
            for (let i = 1; i <= numPaneles; i++) {
                paneles.push({
                    num: i,
                    implementos: [],
                    omitirAlertas: false,
                    funciones: {}
                });
            }
            
            const sorteo = {
                id: Date.now(),
                tipo,
                categorias,
                numPaneles,
                juecesIND,
                jucesCONJ,
                paneles
            };
            
            if (!eventoActual.sorteos) eventoActual.sorteos = [];
            eventoActual.sorteos.push(sorteo);
            
            const index = eventos.findIndex(e => e.id === eventoActual.id);
            eventos[index] = eventoActual;
            guardarDatos();
            
            cerrarModal('modalCrearSorteo');
            renderizarDetalleEvento();
        }

        function renderizarListaSorteos() {
            const sorteos = eventoActual.sorteos || [];
            
            if (sorteos.length === 0) {
                return '<p class="text-center text-gray">No hay sorteos creados</p>';
            }
            
            return sorteos.map(sorteo => `
                <div style="border: 1px solid #e5e7eb; border-radius: 0.375rem; padding: 1rem; margin-bottom: 0.5rem;">
                    <div class="flex-between">
                        <div onclick="verSorteo(${sorteo.id})" style="cursor: pointer; flex: 1;">
                            <h4>${sorteo.tipo} - ${sorteo.categorias.join(', ')}</h4>
                            <p class="text-gray" style="font-size: 0.875rem;">${sorteo.numPaneles} Panel(es)</p>
                        </div>
                        <div class="flex gap-2">
                            <button class="btn btn-secondary btn-sm" onclick="event.stopPropagation(); verSorteo(${sorteo.id})">Ver/Editar</button>
                            <button class="btn btn-danger btn-sm" onclick="event.stopPropagation(); eliminarSorteo(${sorteo.id})">🗑️</button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function eliminarSorteo(sorteoId) {
            if (confirm('¿Eliminar este sorteo?')) {
                eventoActual.sorteos = eventoActual.sorteos.filter(s => s.id !== sorteoId);
                
                const index = eventos.findIndex(e => e.id === eventoActual.id);
                eventos[index] = eventoActual;
                guardarDatos();
                
                renderizarDetalleEvento();
            }
        }

        function verSorteo(sorteoId) {
            sorteoActual = eventoActual.sorteos.find(s => s.id === sorteoId);
            document.getElementById('detalle-evento').classList.add('hidden');
            document.getElementById('detalle-sorteo').classList.remove('hidden');
            renderizarDetalleSorteo();
        }

        function volverEvento() {
            sorteoActual = null;
            document.getElementById('detalle-sorteo').classList.add('hidden');
            document.getElementById('detalle-evento').classList.remove('hidden');
        }

        function renderizarDetalleSorteo() {
            const contenido = document.getElementById('contenidoSorteo');
            const juecesRef = sorteoActual.tipo === 'IND' ? sorteoActual.juecesIND : sorteoActual.jucesCONJ;
            
            contenido.innerHTML = `
                <div class="card">
                    <div class="flex-between">
                        <div>
                            <h2>Sorteo ${sorteoActual.tipo} - ${sorteoActual.categorias.join(', ')}</h2>
                            <p class="text-gray">${eventoActual.nombre}</p>
                        </div>
                        <button class="btn btn-purple" onclick="window.print()">🖨️ Imprimir</button>
                    </div>
                </div>

                <div class="card" id="listado-jueces-sorteo">
                    <h3 style="margin-bottom: 0.5rem;">Jueces ${sorteoActual.tipo}</h3>
                    <div class="grid-3" style="max-height: 200px; overflow-y: auto;">
                        ${juecesRef.map(j => `
                            <div style="font-size: 0.875rem;">
                                <span class="juez-numero" style="width: 25px; height: 25px; line-height: 25px; font-size: 0.75rem;">${j.numero}</span>
                                ${j.nombre} (${j.asoc}) - ${sorteoActual.tipo === 'IND' ? j.ind : j.conj}
                            </div>
                        `).join('')}
                    </div>
                </div>

                <div class="${sorteoActual.paneles.length === 2 ? 'grid-2' : ''}">
                    ${sorteoActual.paneles.map(panel => renderizarPanel(panel, juecesRef)).join('')}
                </div>
            `;
        }

        function renderizarPanel(panel, juecesRef) {
            return `
                <div class="card">
                    <div class="flex-between mb-4">
                        <h3>Panel ${panel.num}</h3>
                        <label style="display: flex; align-items: center; font-size: 0.875rem;">
                            <input type="checkbox" ${panel.omitirAlertas ? 'checked' : ''} onchange="toggleOmitirAlertas(${panel.num})"> Omitir alertas
                        </label>
                    </div>

                    <div class="mb-4">
                        <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Implementos</label>
                        <div class="flex gap-2" style="flex-wrap: wrap;">
                            ${IMPLEMENTOS.map(impl => `
                                <button class="implemento-btn ${panel.implementos.includes(impl) ? 'selected' : ''}" 
                                    onclick="toggleImplemento(${panel.num}, '${impl}')">
                                    ${impl}
                                </button>
                            `).join('')}
                        </div>
                    </div>

                    <div>
                        ${FUNCIONES.map(funcion => {
                            const numero = panel.funciones[funcion] || '';
                            const juez = numero ? juecesRef.find(j => j.numero === parseInt(numero)) : null;
                            const bgClass = verificarConflicto(panel, funcion);
                            
                            return `
                                <div class="funcion-row ${bgClass}">
                                    <input type="number" 
                                        class="funcion-numero" 
                                        value="${numero}" 
                                        placeholder="#"
                                        min="1" 
                                        max="${juecesRef.length}"
                                        onchange="actualizarFuncion(${panel.num}, '${funcion}', this.value)">
                                    <div class="funcion-nombre">${funcion}</div>
                                    <div class="funcion-juez">
                                        ${juez ? `<strong>${juez.nombre}</strong> <span class="text-gray">(${juez.asoc})</span>` : '<span class="text-gray">-</span>'}
                                    </div>
                                </div>
                            `;
                        }).join('')}
                    </div>
                </div>
            `;
        }

        function toggleImplemento(panelNum, impl) {
            const panel = sorteoActual.paneles.find(p => p.num === panelNum);
            if (panel.implementos.includes(impl)) {
                panel.implementos = panel.implementos.filter(i => i !== impl);
            } else {
                panel.implementos.push(impl);
            }
            
            actualizarSorteo();
            renderizarDetalleSorteo();
        }

        function toggleOmitirAlertas(panelNum) {
            const panel = sorteoActual.paneles.find(p => p.num === panelNum);
            panel.omitirAlertas = !panel.omitirAlertas;
            
            actualizarSorteo();
            renderizarDetalleSorteo();
        }

        function actualizarFuncion(panelNum, funcion, numero) {
            const panel = sorteoActual.paneles.find(p => p.num === panelNum);
            if (numero) {
                panel.funciones[funcion] = numero;
            } else {
                delete panel.funciones[funcion];
            }
            
            actualizarSorteo();
            renderizarDetalleSorteo();
        }

        function verificarConflicto(panel, funcion) {
            if (panel.omitirAlertas) return '';
            
            const rubros = {
                'DB1': ['DB1', 'DB2'],
                'DB2': ['DB1', 'DB2'],
                'DA1': ['DA1', 'DA2'],
                'DA2': ['DA1', 'DA2'],
                'A1': ['A1', 'A2', 'A3', 'A4'],
                'A2': ['A1', 'A2', 'A3', 'A4'],
                'A3': ['A1', 'A2', 'A3', 'A4'],
                'A4': ['A1', 'A2', 'A3', 'A4'],
                'E1': ['E1', 'E2', 'E3', 'E4'],
                'E2': ['E1', 'E2', 'E3', 'E4'],
                'E3': ['E1', 'E2', 'E3', 'E4'],
                'E4': ['E1', 'E2', 'E3', 'E4']
            };
            
            if (!rubros[funcion]) return '';
            
            const juecesRef = sorteoActual.tipo === 'IND' ? sorteoActual.juecesIND : sorteoActual.jucesCONJ;
            const funcionesRubro = rubros[funcion];
            const asocs = [];
            
            funcionesRubro.forEach(f => {
                const numero = panel.funciones[f];
                if (numero) {
                    const juez = juecesRef.find(j => j.numero === parseInt(numero));
                    if (juez) asocs.push(juez.asoc);
                }
            });
            
            const numeroActual = panel.funciones[funcion];
            if (numeroActual) {
                const juezActual = juecesRef.find(j => j.numero === parseInt(numeroActual));
                if (juezActual) {
                    const duplicados = asocs.filter(a => a === juezActual.asoc);
                    if (duplicados.length > 1) {
                        return 'alert-warning';
                    }
                }
            }
            
            return '';
        }

        function actualizarSorteo() {
            const sorteoIndex = eventoActual.sorteos.findIndex(s => s.id === sorteoActual.id);
            eventoActual.sorteos[sorteoIndex] = sorteoActual;
            
            const eventoIndex = eventos.findIndex(e => e.id === eventoActual.id);
            eventos[eventoIndex] = eventoActual;
            guardarDatos();
        }

        // ===== EXPORTACIONES E IMPORTACIONES =====

        function exportarPlantilla() {
            const ws = XLSX.utils.json_to_sheet([
                { 'ID-FMG': '', 'Nombre Completo': '', 'ASOC': '', 'IND': '', 'CONJ': '' }
            ]);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Jueces');
            XLSX.writeFile(wb, 'Plantilla_Jueces_GR.xlsx');
        }

        function importarJueces(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = (e) => {
                const data = new Uint8Array(e.target.result);
                const workbook = XLSX.read(data, { type: 'array' });
                const sheet = workbook.Sheets[workbook.SheetNames[0]];
                const jsonData = XLSX.utils.sheet_to_json(sheet);
                
                jsonData.forEach(row => {
                    jueces.push({
                        id: Date.now() + Math.random(),
                        idFmg: (row['ID-FMG'] || '').toString().trim(),
                        nombre: (row['Nombre Completo'] || '').toString().trim(),
                        asoc: (row['ASOC'] || '').toString().trim(),
                        ind: (row['IND'] || '').toString().trim(),
                        conj: (row['CONJ'] || '').toString().trim()
                    });
                });
                
                jueces.sort((a, b) => a.nombre.localeCompare(b.nombre));
                guardarDatos();
                renderizarJueces();
                alert('Jueces importados exitosamente');
            };
            reader.readAsArrayBuffer(file);
            event.target.value = '';
        }

        function exportarBD() {
            const data = jueces.map(j => ({
                'ID-FMG': j.idFmg,
                'Nombre Completo': j.nombre,
                'ASOC': j.asoc,
                'IND': j.ind,
                'CONJ': j.conj
            }));
            
            const ws = XLSX.utils.json_to_sheet(data);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Base_Datos_Jueces');
            XLSX.writeFile(wb, 'BD_Jueces_GR_Completa.xlsx');
        }

        function exportarBackup() {
            const backup = {
                jueces,
                eventos,
                version: '1.0',
                fecha: new Date().toISOString()
            };
            
            const blob = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `Backup_GR_${new Date().toISOString().split('T')[0]}.json`;
            a.click();
        }

        function importarBackup(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const backup = JSON.parse(e.target.result);
                    jueces = backup.jueces || [];
                    eventos = backup.eventos || [];
                    guardarDatos();
                    renderizarJueces();
                    renderizarEventos();
                    alert('Backup restaurado exitosamente');
                    cambiarSeccion('jueces');
                } catch (error) {
                    alert('Error al leer el backup');
                }
            };
            reader.readAsText(file);
            event.target.value = '';
        }

        // ===== UTILIDADES =====

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.classList.remove('active');
                }
            });
        });
    </script>
</body>
</html>
