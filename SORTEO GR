function importarJueces(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = (e) => {
        const data = new Uint8Array(e.target.result);
        const workbook = XLSX.read(data, { type: 'array' });
        const sheet = workbook.Sheets[workbook.SheetNames[0]];
        const jsonData = XLSX.utils.sheet_to_json(sheet);
        
        let importados = 0;
        let duplicados = 0;
        const listaDuplicados = []; // Guardar info de duplicados
        
        jsonData.forEach(row => {
            const idFmg = (row['ID-FMG'] || '').toString().trim();
            const nombre = (row['Nombre Completo'] || '').toString().trim();
            const asoc = (row['ASOC'] || '').toString().trim();
            const ind = (row['IND'] || '').toString().trim();
            const conj = (row['CONJ'] || '').toString().trim();
            
            // Verificar si ya existe
            let existente = null;
            let motivoDuplicado = '';
            
            // 1. Verificar por ID-FMG (si tiene ID-FMG y no está vacío)
            if (idFmg) {
                existente = jueces.find(j => j.idFmg && String(j.idFmg).toLowerCase() === String(idFmg).toLowerCase());
                if (existente) {
                    motivoDuplicado = `ID-FMG: ${idFmg}`;
                }
            }
            
            // 2. Si no existe por ID-FMG, verificar por nombre exacto
            if (!existente && nombre) {
                existente = jueces.find(j => j.nombre && String(j.nombre).toLowerCase() === String(nombre).toLowerCase());

                if (existente) {
                    motivoDuplicado = `Nombre: ${nombre}`;
                }
            }
            
            if (existente) {
                // YA EXISTE - No importar, solo contar
                duplicados++;
                listaDuplicados.push({
                    motivo: motivoDuplicado,
                    nombre: nombre,
                    idFmg: idFmg,
                    asoc: asoc
                });
            } else {
                // NO EXISTE - Importar
                jueces.push({
                    id: Date.now() + Math.random(),
                    idFmg: idFmg,
                    nombre: nombre,
                    asoc: asoc,
                    ind: ind,
                    conj: conj
                });
                importados++;
            }
        });
        
        // Ordenar y guardar
        jueces.sort((a, b) => a.nombre.localeCompare(b.nombre));
        guardarDatos();
        renderizarJueces();
        
        // Mostrar resumen detallado
        let mensaje = '═══════════════════════════════════\n';
        mensaje += '📊 RESUMEN DE IMPORTACIÓN\n';
        mensaje += '═══════════════════════════════════\n\n';
        
        mensaje += `✅ Jueces nuevos importados: ${importados}\n`;
        mensaje += `⚠️ Duplicados detectados (NO importados): ${duplicados}\n`;
        mensaje += `📋 Total procesados: ${importados + duplicados}\n`;
        
        if (duplicados > 0) {
            mensaje += '\n───────────────────────────────────\n';
            mensaje += '⚠️ DUPLICADOS ENCONTRADOS:\n';
            mensaje += '(No se importaron porque ya existen)\n';
            mensaje += '───────────────────────────────────\n\n';
            
            // Mostrar hasta 15 duplicados
            const maxMostrar = 15;
            listaDuplicados.slice(0, maxMostrar).forEach((dup, index) => {
                mensaje += `${index + 1}. ${dup.nombre}\n`;
                mensaje += `   • ${dup.motivo}\n`;
                if (dup.asoc) mensaje += `   • Asociación: ${dup.asoc}\n`;
                mensaje += '\n';
            });
            
            if (listaDuplicados.length > maxMostrar) {
                mensaje += `... y ${listaDuplicados.length - maxMostrar} duplicados más\n`;
            }
        }
        
        mensaje += '\n═══════════════════════════════════';
        
        alert(mensaje);
    };
    reader.readAsArrayBuffer(file);
    event.target.value = '';
}

