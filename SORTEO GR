                                            </tr>
                                        `).join('')
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div>
                        <h4 style="margin-bottom: 0.5rem;">Jueces Conjuntos (CONJ)</h4>
                        <div class="scroll-x">
                            <table>
                                <thead>
                                    <tr>
                                        <th>N°</th>
                                        <th>Nombre</th>
                                        <th>ASOC</th>
                                        <th>CONJ</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${jucesCONJ.length === 0 ? '<tr><td colspan="5" class="text-center text-gray">No hay jueces CONJ</td></tr>' : 
                                        jucesCONJ.map((j, idx) => `
                                            <tr>
                                                <td><span class="juez-numero">${idx + 1}</span></td>
                                                <td>${j.nombre}</td>
                                                <td>${j.asoc}</td>
                                                <td>${j.conj}</td>
                                                <td>
                                                    <button class="btn btn-secondary btn-sm" onclick="editarJuezEvento(${j.id})">✏️</button>
                                                    <button class="btn btn-danger btn-sm" onclick="eliminarJuezEvento(${j.id})">🗑️</button>
                                                </td>
                                            </tr>
                                        `).join('')
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="flex-between mb-4">
                        <h3>Sorteos</h3>
                        <button class="btn btn-primary" onclick="abrirModalCrearSorteo()">+ Nuevo Sorteo</button>
                    </div>
                    ${renderizarListaSorteos()}
                </div>
            `;
