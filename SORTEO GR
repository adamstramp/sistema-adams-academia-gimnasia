        function ordenarJueces(juecesArray, campo) {
            return juecesArray.sort((a, b) => {
                const indexA = NIVELES_ORDEN.indexOf(a[campo]);
                const indexB = NIVELES_ORDEN.indexOf(b[campo]);
                return indexA - indexB;
            });
        }

        function mostrarSelectorJueces() {
            juecesSeleccionados = (eventoActual.jueces || []).map(j => j.id);
            const tbody = document.querySelector('#tablaSelectorJueces tbody');
            tbody.innerHTML = '';
            
            jueces.forEach(juez => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><input type="checkbox" ${juecesSeleccionados.includes(juez.id) ? 'checked' : ''} onchange="toggleJuezSelector(${juez.id})"></td>
                    <td>${juez.nombre}</td>
                    <td>${juez.asoc}</td>
                    <td>${juez.ind}</td>
                    <td>${juez.conj}</td>
                `;
                tbody.appendChild(tr);
            });
            
            actualizarContadorSeleccionados();
            document.getElementById('modalSelectorJueces').classList.add('active');
        }

        function toggleJuezSelector(id) {
            if (juecesSeleccionados.includes(id)) {
                juecesSeleccionados = juecesSeleccionados.filter(jid => jid !== id);
            } else {
                juecesSeleccionados.push(id);
            }
            actualizarContadorSeleccionados();
        }

        function actualizarContadorSeleccionados() {
            document.getElementById('contadorSeleccionados').textContent = `${juecesSeleccionados.length} jueces seleccionados`;
        }

function filtrarJuecesSelector() {
    const filtro = document.getElementById('filtroJueces').value.toLowerCase();
    const tbody = document.querySelector('#tablaSelectorJueces tbody');
    tbody.innerHTML = '';
    
    const jucesFiltrados = jueces.filter(j => {
const nombre = String(j.nombre || '').toLowerCase();
const asoc = String(j.asoc || '').toLowerCase();
const ind = String(j.ind || '').toLowerCase();
const conj = String(j.conj || '').toLowerCase();
        
        return nombre.includes(filtro) ||
               asoc.includes(filtro) ||
               ind.includes(filtro) ||
               conj.includes(filtro);
    });
    
    jucesFiltrados.forEach(juez => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td><input type="checkbox" ${juecesSeleccionados.includes(juez.id) ? 'checked' : ''} onchange="toggleJuezSelector(${juez.id})"></td>
            <td>${juez.nombre || ''}</td>
            <td>${juez.asoc || ''}</td>
            <td>${juez.ind || ''}</td>
            <td>${juez.conj || ''}</td>
        `;
        tbody.appendChild(tr);
    });
}

        function guardarJuecesEvento() {
            const juecesToAdd = jueces.filter(j => juecesSeleccionados.includes(j.id));
