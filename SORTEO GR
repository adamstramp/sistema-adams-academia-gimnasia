    <script>
        // Constantes
        const NIVELES_ORDEN = ['INT', '1', '2', '3', '4', '5', 'AUX', 'CTN'];
        const CATEGORIAS_IND = ['PRE - I', 'I - A', 'I - B', 'II - A', 'II - B', 'III - A', 'III - B', 'III - C', 'PRE - III', 'IV - A', 'IV - B', 'IV - C', 'V - A', 'V - B', 'V - C', 'V - D', 'VIII - A', 'VIII - B', 'VIII - C', 'VIII - D', 'VIII - E', 'VIII - F'];
        const CATEGORIAS_CONJ = ['Conjunto JUV', 'Conjunto MAY', 'Conjunto INF A', 'Conjunto INF B', 'Conjunto INF C', 'Formativo V - A', 'Formativo V - B', 'Formativo V - C', 'VI - A', 'VI - B', 'VI - C', 'VII - A', 'VII - B', 'VII - C'];
        const IMPLEMENTOS = ['ML', 'CUE', 'ARO', 'PEL', 'CLA', 'CIN', 'OPCIONAL', 'MIXTO'];
        const FUNCIONES = ['DB1', 'DB2', 'DA1', 'DA2', 'A1', 'A2', 'A3', 'A4', 'E1', 'E2', 'E3', 'E4', 'MUS', 'Res', 'L1', 'L2', 'T', 'JC1', 'JC2', 'JC3', 'JC4', 'J. SUP'];

        // Variables globales
        let jueces = [];
        let eventos = [];
        let editandoJuezId = null;
        let editandoEventoId = null;
        let eventoActual = null;
        let sorteoActual = null;
        let editandoJuezEventoId = null;
        let juecesSeleccionados = [];

        // Inicialización
        cargarDatos();
        renderizarJueces();

        function cargarDatos() {
            const datosGuardados = localStorage.getItem('grSorteos');
            if (datosGuardados) {
                const datos = JSON.parse(datosGuardados);
                jueces = datos.jueces || [];
                eventos = datos.eventos || [];
            }
        }

        function guardarDatos() {
            localStorage.setItem('grSorteos', JSON.stringify({ jueces, eventos }));
        }

        function cambiarSeccion(seccion) {
            document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
            document.getElementById('nav' + seccion.charAt(0).toUpperCase() + seccion.slice(1)).classList.add('active');
            
            document.getElementById('seccion-jueces').classList.add('hidden');
            document.getElementById('seccion-eventos').classList.add('hidden');
            document.getElementById('seccion-backup').classList.add('hidden');
            document.getElementById('detalle-evento').classList.add('hidden');
            document.getElementById('detalle-sorteo').classList.add('hidden');
            
            if (seccion === 'jueces') {
                document.getElementById('seccion-jueces').classList.remove('hidden');
                renderizarJueces();
            } else if (seccion === 'eventos') {
                document.getElementById('seccion-eventos').classList.remove('hidden');
                renderizarEventos();
                eventoActual = null;
                sorteoActual = null;
            } else if (seccion === 'backup') {
                document.getElementById('seccion-backup').classList.remove('hidden');
            }
        }

        // ===== GESTIÓN DE JUECES =====

        function mostrarFormJuez(id = null) {
            editandoJuezId = id;
            const modal = document.getElementById('modalJuez');
            const titulo = document.getElementById('modalJuezTitulo');
            
            if (id) {
                const juez = jueces.find(j => j.id === id);
                titulo.textContent = 'Editar Juez';
                document.getElementById('juezIdFmg').value = juez.idFmg;
                document.getElementById('juezNombre').value = juez.nombre;
                document.getElementById('juezAsoc').value = juez.asoc;
                document.getElementById('juezInd').value = juez.ind;
                document.getElementById('juezConj').value = juez.conj;
            } else {
                titulo.textContent = 'Nuevo Juez';
                document.getElementById('juezIdFmg').value = '';
                document.getElementById('juezNombre').value = '';
                document.getElementById('juezAsoc').value = '';
                document.getElementById('juezInd').value = '';
                document.getElementById('juezConj').value = '';
            }
            
            modal.classList.add('active');
        }

        function guardarJuez() {
            const nombre = document.getElementById('juezNombre').value.trim();
            const asoc = document.getElementById('juezAsoc').value.trim();
            
            if (!nombre || !asoc) {
                alert('Nombre y Asociación son obligatorios');
                return;
            }
            
            const juezData = {
                idFmg: document.getElementById('juezIdFmg').value.trim(),
                nombre,
                asoc,
                ind: document.getElementById('juezInd').value.trim(),
                conj: document.getElementById('juezConj').value.trim()
            };
            
            if (editandoJuezId) {
                const index = jueces.findIndex(j => j.id === editandoJuezId);
                jueces[index] = { ...juezData, id: editandoJuezId };
            } else {
                jueces.push({ ...juezData, id: Date.now() });
            }
            
            jueces.sort((a, b) => a.nombre.localeCompare(b.nombre));
            guardarDatos();
            renderizarJueces();
            cerrarModal('modalJuez');
        }

        function eliminarJuez(id) {
            if (confirm('¿Está seguro de eliminar este juez?')) {
                jueces = jueces.filter(j => j.id !== id);
                guardarDatos();
                renderizarJueces();
            }
        }

        function renderizarJueces() {
            const tbody = document.querySelector('#tablaJueces tbody');
            tbody.innerHTML = '';
            
            if (jueces.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-gray">No hay jueces registrados</td></tr>';
                return;
            }
            
            jueces.forEach(juez => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${juez.idFmg}</td>
                    <td>${juez.nombre}</td>
                    <td>${juez.asoc}</td>
                    <td>${juez.ind}</td>
                    <td>${juez.conj}</td>
                    <td>
                        <button class="btn btn-secondary btn-sm" onclick="mostrarFormJuez(${juez.id})">✏️</button>
                        <button class="btn btn-danger btn-sm" onclick="eliminarJuez(${juez.id})">🗑️</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function ordenarTabla(campo) {
            jueces.sort((a, b) => {
                if (a[campo] < b[campo]) return -1;
                if (a[campo] > b[campo]) return 1;
                return 0;
            });
            renderizarJueces();
        }

        // ===== GESTIÓN DE EVENTOS =====

        function mostrarFormEvento(id = null) {
            editandoEventoId = id;
            const modal = document.getElementById('modalEvento');
            const titulo = document.getElementById('modalEventoTitulo');
            
            if (id) {
                const evento = eventos.find(e => e.id === id);
                titulo.textContent = 'Editar Evento';
                document.getElementById('eventoNombre').value = evento.nombre;
                document.getElementById('eventoSede').value = evento.sede;
                document.getElementById('eventoFecha').value = evento.fecha;
                document.getElementById('eventoFechaInicio').value = evento.fechaInicio;
            } else {
                titulo.textContent = 'Nuevo Evento';
                document.getElementById('eventoNombre').value = '';
                document.getElementById('eventoSede').value = '';
                document.getElementById('eventoFecha').value = '';
                document.getElementById('eventoFechaInicio').value = new Date().toISOString().split('T')[0];
            }
            
            modal.classList.add('active');
        }

        function guardarEvento() {
            const nombre = document.getElementById('eventoNombre').value.trim();
            const sede = document.getElementById('eventoSede').value.trim();
            const fecha = document.getElementById('eventoFecha').value.trim();
            
            if (!nombre || !sede || !fecha) {
                alert('Todos los campos son obligatorios');
                return;
            }
            
            const eventoData = {
                nombre,
                sede,
                fecha,
                fechaInicio: document.getElementById('eventoFechaInicio').value
            };
            
            if (editandoEventoId) {
                const index = eventos.findIndex(e => e.id === editandoEventoId);
                eventos[index] = { ...eventos[index], ...eventoData };
            } else {
                eventos.push({ 
                    ...eventoData, 
                    id: Date.now(), 
                    jueces: [], 
                    sorteos: [] 
                });
            }
            
            guardarDatos();
            renderizarEventos();
            cerrarModal('modalEvento');
        }

        function eliminarEvento(id) {
            if (confirm('¿Eliminar este evento y todos sus sorteos?')) {
                eventos = eventos.filter(e => e.id !== id);
                guardarDatos();
                renderizarEventos();
            }
        }

        function renderizarEventos() {
            const lista = document.getElementById('listaEventos');
            lista.innerHTML = '';
            
            if (eventos.length === 0) {
                lista.innerHTML = '<div class="card text-center text-gray">No hay eventos creados</div>';
                return;
            }
            
            const eventosOrdenados = [...eventos].sort((a, b) => new Date(b.fechaInicio) - new Date(a.fechaInicio));
            
            eventosOrdenados.forEach(evento => {
                const div = document.createElement('div');
                div.className = 'card';
                div.innerHTML = `
                    <div class="flex-between">
                        <div onclick="verEvento(${evento.id})" style="cursor: pointer; flex: 1;">
                            <h3>${evento.nombre}</h3>
                            <p class="text-gray">Sede: ${evento.sede}</p>
                            <p class="text-gray">Fecha: ${evento.fecha}</p>
                            <p class="text-gray" style="font-size: 0.875rem; margin-top: 0.5rem;">
                                ${(evento.jueces || []).length} jueces | ${(evento.sorteos || []).length} sorteos
                            </p>
                        </div>
                        <div class="flex gap-2">
                            <button class="btn btn-secondary btn-sm" onclick="event.stopPropagation(); mostrarFormEvento(${evento.id})">✏️</button>
                            <button class="btn btn-danger btn-sm" onclick="event.stopPropagation(); eliminarEvento(${evento.id})">🗑️</button>
                        </div>
                    </div>
                `;
                lista.appendChild(div);
            });
        }

        function verEvento(id) {
            eventoActual = eventos.find(e => e.id === id);
            document.getElementById('seccion-eventos').classList.add('hidden');
            document.getElementById('detalle-evento').classList.remove('hidden');
            renderizarDetalleEvento();
        }

        function volverEventos() {
            eventoActual = null;
            sorteoActual = null;
            document.getElementById('detalle-evento').classList.add('hidden');
            document.getElementById('detalle-sorteo').classList.add('hidden');
            document.getElementById('seccion-eventos').classList.remove('hidden');
        }

function renderizarDetalleEvento() {
    const contenido = document.getElementById('contenidoEvento');
    
    const juecesEvento = eventoActual.jueces || [];
    const juecesIND = ordenarJueces(juecesEvento.filter(j => j.ind), 'ind');
    const jucesCONJ = ordenarJueces(juecesEvento.filter(j => j.conj), 'conj');
    
    contenido.innerHTML = `
        <div class="card">
            <h2>${eventoActual.nombre}</h2>
            <p class="text-gray">Sede: ${eventoActual.sede}</p>
            <p class="text-gray">Fecha: ${eventoActual.fecha}</p>
        </div>

        <!-- PRIMERO: SECCIÓN DE SORTEOS -->
        <div class="card">
            <div class="flex-between mb-4">
                <h3>Sorteos</h3>
                <button class="btn btn-primary" onclick="abrirModalCrearSorteo()">+ Nuevo Sorteo</button>
            </div>
            ${renderizarListaSorteos()}
        </div>

        <!-- SEGUNDO: SECCIÓN DE JUECES -->
        <div class="card">
            <div class="flex-between mb-4">
                <h3>Jueces Participantes</h3>
                <div class="flex gap-2">
                    <button class="btn btn-success btn-sm" onclick="mostrarFormJuez()">Agregar a BD General</button>
                    <button class="btn btn-primary" onclick="mostrarSelectorJueces()">Seleccionar Jueces</button>
                </div>
            </div>

            <!-- Jueces en dos columnas: IND izquierda, CONJ derecha -->
            <div class="grid-2">
                <!-- Columna IND -->
