    let visible = true;
    
    if (panel.funciones[funcion]) {
        if (typeof panel.funciones[funcion] === 'object') {
            numero = panel.funciones[funcion].numero || '';
            visible = panel.funciones[funcion].visible !== false;
        } else {
            numero = panel.funciones[funcion];
            visible = true;
        }
    }
    
    const juez = numero ? juecesRef.find(j => j.numero === parseInt(numero)) : null;
    const bgClass = verificarConflicto(panel, funcion);
    
    // Determinar sección por color
    let seccionClass = 'seccion-otros';
    if (['DB1', 'DB2'].includes(funcion)) seccionClass = 'seccion-db';
    else if (['DA1', 'DA2'].includes(funcion)) seccionClass = 'seccion-da';
    else if (['A1', 'A2', 'A3', 'A4'].includes(funcion)) seccionClass = 'seccion-a';
    else if (['E1', 'E2', 'E3', 'E4'].includes(funcion)) seccionClass = 'seccion-e';
    
return `
    <div class="funcion-row ${seccionClass} ${bgClass}" data-visible="${visible}">
